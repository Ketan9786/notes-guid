 {
  "percentage": {
    "chapter": "Percentage",
    "subject": "Maths",
    "exam": "SSC CGL",
    "topics": [
      {
        "id": "basic",
        "title": "Basic Percentage",
        "icon": "📊",
        "badge": "Q1, Q2, Q3, Q4",
        "badgeColor": "blue",
        "summary": "Finding x% of a number, or what % one number is of another.",
        "cards": [
          {
            "type": "concept",
            "title": "Core formulas",
            "formulas": [
              "x% of N = N × x/100",
              "A is what % of B? → (A/B) × 100"
            ],
            "steps": [
              "Convert % to fraction using fraction table (1/4=25%, 1/5=20%, 1/8=12.5%...)",
              "For chain %: multiply all fractions together",
              "25% of 40% of 2100 = (1/4) × (2/5) × 2100"
            ],
            "examples": [
              "Q2: 25% of 40% of (2/7) of 2100 = (1/4)×(2/5)×(2/7)×2100 = 60",
              "Q3: 55% boys → 45% girls = 90 → total = 200, boys = 110"
            ]
          },
          {
            "type": "concept",
            "title": "A is x% more/less than B",
            "badge": "Q1",
            "badgeColor": "green",
            "formulas": [
              "A is 25% more than B → A:B = 125:100 = 5:4",
              "B less than A by? → Difference/A × 100"
            ],
            "steps": [
              "Write ratio: A:B = (100+x):100",
              "Reverse % = difference / (larger number) × 100"
            ],
            "examples": [
              "Q1: Reeta 25% more than Geeta → R:G = 5:4 → Geeta less than Reeta = 1/5 × 100 = 20%"
            ]
          }
        ]
      },
      {
        "id": "fractions",
        "title": "Key Fractions",
        "icon": "🔢",
        "badge": "Q5, Q14, Q15",
        "badgeColor": "blue",
        "summary": "Key fraction-to-percentage conversions and fraction manipulation.",
        "cards": [
          {
            "type": "table",
            "title": "Fraction table to memorise",
            "rows": [
              ["1/2 = 50%", "1/3 = 33.33%", "1/4 = 25%"],
              ["1/5 = 20%", "1/6 = 16.66%", "1/7 = 14.28%"],
              ["1/8 = 12.5%", "1/9 = 11.11%", "1/10 = 10%"],
              ["1/20 = 5%", "3/8 = 37.5%", "5/8 = 62.5%"]
            ],
            "tip": "37.5% more → ×11/8 | 37.5% less → ×5/8 | 37.5% of → ×3/8"
          },
          {
            "type": "concept",
            "title": "Numerator / denominator changed",
            "badge": "Q14, Q15",
            "badgeColor": "blue",
            "formulas": [
              "New = Original × (100+a)/(100−b)",
              "Set new fraction = given value, solve for original"
            ],
            "steps": [
              "Let original fraction = N/D",
              "Apply % change to N and D separately",
              "Set result equal to given fraction and solve"
            ],
            "examples": [
              "Q15: N↑140% → ×12/5, D↓20% → ×4/5. Result=12/7 → original = 4/7",
              "Q14: 1/5 % = (1/5) ÷ 100 = 1/500"
            ]
          }
        ]
      },
      {
        "id": "successive",
        "title": "Successive %",
        "icon": "🔁",
        "badge": "Q9, Q10, Q11, Q13",
        "badgeColor": "blue",
        "summary": "When a value is changed multiple times one after another.",
        "cards": [
          {
            "type": "concept",
            "title": "Successive % formulas",
            "formulas": [
              "Both ↑: net % = x + y + xy/100",
              "Both ↓: net % = −x − y + xy/100",
              "One ↑, one ↓: net % = x − y − xy/100"
            ],
            "steps": [
              "Identify sign of each change (+ for increase, − for decrease)",
              "Plug into formula with correct signs",
              "Or use multiply method: Final = P × (100+x)/100 × (100+y)/100"
            ],
            "examples": [
              "Q11: +15% then +40% → 15+40+(600/100) = 61%",
              "Q10: Price ↓25%, visitors ↑50% → −25+50−(−1250/100) = +12.5%",
              "Q13: ↑10%,↑5%,↑15% → 1.10×1.05×1.15 − 1 = 32.825% ≈ 32 33/40%"
            ]
          },
          {
            "type": "concept",
            "title": "Number changed multiple times",
            "badge": "Q8, Q9",
            "badgeColor": "green",
            "steps": [
              "Let original = 100",
              "Apply each % change step by step",
              "Compare final with 100 to get net % change"
            ],
            "examples": [
              "Q9: ↑25% then ↓16%: 100 → 125 → 105 → net = +5%",
              "Q8: ↓20% then ↑200%: 100→80→240. Diff(3,1)=140, Diff(2,3)=160 → 140 is 12.5% less than 160"
            ]
          }
        ]
      },
      {
        "id": "price_consumption",
        "title": "Price & Consumption",
        "icon": "🛒",
        "badge": "Q27, Q28, Q29",
        "badgeColor": "amber",
        "summary": "Expenditure = Price × Consumption. Price and consumption move inversely to keep expenditure same.",
        "cards": [
          {
            "type": "concept",
            "title": "Expenditure stays same",
            "formulas": [
              "Price ↑x% → reduce consumption by x/(100+x) × 100",
              "Price ↓x% → can increase consumption by x/(100−x) × 100"
            ],
            "steps": [
              "Write price ratio old:new (e.g. 100:165 for +65%)",
              "Consumption ratio = new:old (reverse)",
              "Reduction % = difference / new price × 100"
            ],
            "examples": [
              "Q27: CNG ↑65% → reduce by 65/165 × 100 = 39.39%",
              "Q28: Onion 60→75 (+25%) → reduce by 15/75 × 100 = 20%",
              "Q29: Production ↓35% → hours ↑ by 35/65 × 100 = 53.85%"
            ]
          },
          {
            "type": "concept",
            "title": "Revenue = Price × Sales",
            "badge": "Q10, Q12",
            "badgeColor": "amber",
            "formulas": [
              "% change in revenue = p + s + (p×s/100)"
            ],
            "examples": [
              "Q12: Price ↑12.5%, Sales ↑8.5% → 21 + 1.0625 = 22.0625%"
            ]
          }
        ]
      },
      {
        "id": "income_savings",
        "title": "Income & Savings",
        "icon": "💰",
        "badge": "Q30, Q31, Q32, Q33",
        "badgeColor": "blue",
        "summary": "Income = Expenditure + Savings. Track all three when any one changes.",
        "cards": [
          {
            "type": "concept",
            "title": "Core identity",
            "formulas": [
              "Income = Expenditure + Savings",
              "Savings % = 100 − Expenditure %"
            ],
            "steps": [
              "Let income = 100. Set exp and savings from given %",
              "Apply new income (e.g. ↑15% → income becomes 115)",
              "Calculate new expenditure with its own % change",
              "New savings = New income − New expenditure",
              "% change in savings = (New − Old) / Old × 100"
            ],
            "examples": [
              "Q31: Income=100, exp=70, savings=30. New income=115, new exp=75.25. Savings=39.75 → ↑32.5%",
              "Q30: Savings=40% → exp=60%. Avg exp=₹21000 → total=₹42000 → income = ₹70,000"
            ]
          }
        ]
      },
      {
        "id": "election",
        "title": "Election",
        "icon": "🗳",
        "badge": "Q21–Q26",
        "badgeColor": "red",
        "summary": "Two methods depending on whether candidate % is of total or valid votes.",
        "cards": [
          {
            "type": "concept",
            "title": "When to use which method",
            "tip": "Candidate % of VALID votes → Successive method | Candidate % of TOTAL votes → Tree method"
          },
          {
            "type": "concept",
            "title": "Tree method — candidate % of total votes",
            "formulas": [
              "Total → Cast + Not cast → Valid + Invalid → A + B"
            ],
            "steps": [
              "Start from 100% total voters",
              "Deduct % not voted to get % voted",
              "Deduct % invalid to get % valid",
              "Apply candidate % on valid",
              "Winner − Loser = given margin → solve for total"
            ],
            "examples": [
              "Q26: 30% didn't vote → 70% voted. 20% invalid → 56% valid. Winner=64%→35.84%. Diff=15.68%=3136 → Total=20,000"
            ]
          },
          {
            "type": "concept",
            "title": "Successive method — candidate % of valid votes",
            "badge": "Q23, Q24",
            "badgeColor": "red",
            "steps": [
              "Valid votes = candidate votes / candidate's % of valid",
              "Total cast = valid / (1 − invalid%)",
              "Total voters = total cast / (% who voted)"
            ],
            "examples": [
              "Q23: Jeeta=91800=60% of valid → valid=153000. Cast=153000/0.85. Total=180000/0.90 = 2,00,000"
            ]
          }
        ]
      },
      {
        "id": "pass_fail",
        "title": "Pass / Fail",
        "icon": "📋",
        "badge": "Q34, Q35, Q36",
        "badgeColor": "blue",
        "summary": "Find max marks or passing marks from failure/pass margins.",
        "cards": [
          {
            "type": "concept",
            "title": "Core formulas",
            "formulas": [
              "Pass marks = scored + marks short (if failed)",
              "Pass marks = scored − excess (if passed)",
              "Max marks = Pass marks / Pass% × 100"
            ],
            "examples": [
              "Q34: 210 marks, fails by 14 → pass=224. Pass%=35% → Max = 640",
              "Q35: 20%→fail 25. 50%→pass 20. Diff=30%=45 marks → Max=150. Pass = 55"
            ]
          },
          {
            "type": "concept",
            "title": "Two-student method",
            "badge": "Q36",
            "badgeColor": "amber",
            "steps": [
              "Student 1 fails: pass = a%×M + x",
              "Student 2 passes: pass = b%×M − y",
              "Equate and solve for M"
            ],
            "examples": [
              "Q36: 20%M + 30 = 32%M − 42 → 12%M = 72 → M = 600"
            ]
          }
        ]
      },
      {
        "id": "venn",
        "title": "Venn Diagram",
        "icon": "⭕",
        "badge": "Q37",
        "badgeColor": "amber",
        "summary": "Find % who passed both subjects when individual pass % and fail-both % are given.",
        "cards": [
          {
            "type": "concept",
            "title": "Two-subject formula",
            "formulas": [
              "Passed both = Pass(A) + Pass(B) + Fail(both) − 100"
            ],
            "steps": [
              "Failed(A only) = 100−Pass(A) − Fail(both)",
              "Failed(B only) = 100−Pass(B) − Fail(both)",
              "Total failed at least one = A only + B only + both",
              "Passed both = 100 − total failed"
            ],
            "examples": [
              "Q37: Pass H=45%, Pass Hi=60%, Fail both=8%",
              "Fail H only=47%, Fail Hi only=32%, Fail both=8% → total fail=87% → passed both = 13%"
            ]
          }
        ]
      },
      {
        "id": "population",
        "title": "Population",
        "icon": "👥",
        "badge": "Q18, Q19, Q20",
        "badgeColor": "green",
        "summary": "Population changes over multiple years. Find original or final using multiplication.",
        "cards": [
          {
            "type": "concept",
            "title": "Year-by-year multiplication",
            "formulas": [
              "Final = Initial × (100+r₁)/100 × (100+r₂)/100 × ...",
              "Initial = Final ÷ (product of all year factors)"
            ],
            "steps": [
              "Write each year's factor: ↑5% → ×21/20, ↓6% → ×94/100",
              "Multiply all factors",
              "If finding initial: divide final by the product"
            ],
            "examples": [
              "Q20: ↑5% then ↓6%: P × 21/20 × 94/100 = 35532 → P = 36,000",
              "Q18: Decrease = (156940−141246)/156940 × 100 = 10%"
            ]
          }
        ]
      },
      {
        "id": "weighted_avg",
        "title": "Weighted Average",
        "icon": "⚖",
        "badge": "Q16, Q17",
        "badgeColor": "green",
        "summary": "Find overall % when each component has a different weight.",
        "cards": [
          {
            "type": "concept",
            "title": "Weighted average formula",
            "formulas": [
              "Weighted % = Σ(marks% × weight) / Σ(weights)"
            ],
            "steps": [
              "Multiply each subject's scored % by its weight",
              "Sum all products",
              "Divide by total weight (= 100 if weights sum to 100)"
            ],
            "examples": [
              "Q17: 75×40 + 80×50 + 60×10 = 3000+4000+600 = 7600 / 100 = 76%"
            ]
          }
        ]
      }
    ]
  }
}